# Replace all default credentials before deploying outside local development.
MYSQL_DATABASE=droppa
MYSQL_USER=droppa
MYSQL_PASSWORD=droppa-local-password
MYSQL_ROOT_PASSWORD=droppa-local-root-password
MYSQL_HOST_PORT=3308
KAFKA_HOST_PORT=29092
JPA_DDL_AUTO=update

# Must be identical for the user service and API gateway, and at least 32 bytes.
JWT_SECRET=replace-with-a-long-random-secret-of-at-least-32-bytes

GATEWAY_PORT=8089
JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=75.0

# Server-owned booking tariffs
BOOKING_PRICE_MINI_VAN=350.00
BOOKING_PRICE_ONE_TON=500.00
BOOKING_PRICE_ONE_POINT_FIVE_TON=650.00
BOOKING_PRICE_FOUR_TON=1200.00
BOOKING_PRICE_EIGHT_TON=2000.00
BOOKING_PRICE_ADDITIONAL_LOAD=100.00
BOOKING_PRICE_LABOUR=150.00

# Optional SMTP configuration used for account emails.
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_STARTTLS_ENABLE=true
